{
  "name": "back-end",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "dev": "NODE_ENV=dev nest start --watch",
    "debug": "nest start --debug --watch",
    "prod": "NODE_ENV=prod node dist/main.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate:dev": "NODE_ENV=dev drizzle-kit migrate",
    "db:migrate:prod": "NODE_ENV=prod drizzle-kit migrate",
    "db:seed": "tsx src/db/scripts/seed.ts"
  },
  "dependencies": {
    "@/common": "workspace:^",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.2.6",
    "@scalar/nestjs-api-reference": "^1.0.27",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "fast-csv": "^5.0.5",
    "multer": "^2.0.2",
    "nestjs-zod": "^5.1.1",
    "pg": "^8.18.0",
    "pg-native": "^3.5.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "shapefile": "^0.6.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@types/express": "^5.0.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.10.7",
    "@types/pg": "^8.16.0",
    "@types/shapefile": "^0.6.4",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  }
}
